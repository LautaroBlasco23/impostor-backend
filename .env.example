# Server
PORT=8080

# Redis
REDIS_URL=redis://impostor-redis:6379

# PostgreSQL
POSTGRES_URL=postgres://postgres:postgres@impostor-postgres:5432/gamedb?sslmode=disable

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Nginx domains
FRONTEND_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
